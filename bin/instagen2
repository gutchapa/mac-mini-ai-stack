#!/usr/bin/env python3
"""
InstaGen v2 - Advanced School Instagram Content Generator
Features:
  1. Vision analysis (Gemma 4 sees the photo)
  2. Creative contextual text overlays
  3. Video reel creation from photos
  4. Storytelling captions
  5. Multiple creative templates

Usage:
  instagen2 -i ~/Desktop/photos -e "Cooking Class" --style storytelling
"""

import os
import sys
import argparse
import subprocess
import json
import random
from pathlib import Path
from PIL import Image, ImageDraw, ImageFont, ImageFilter, ImageEnhance
import shutil

SCHOOL_NAME = "Bodhana Learning Tree"
VISION_MODEL = "gemma4:e4b-q4"

SIZES = {
    "post": (1080, 1080),
    "portrait": (1080, 1350),
    "reel": (1080, 1920),
    "story": (1080, 1920),
}

TEXT_STYLES = {
    "storytelling": {
        "prompt": "Look at this image from a school event. Write ONE short, creative text overlay (max 8 words) that tells a story. Like 'From 200 gm to 3 kg' or 'Little hands, big dreams'. Just the text, nothing else.",
        "position": "center",
        "bg_style": "gradient",
    },
    "quote": {
        "prompt": "Look at this school image. Write ONE inspiring quote or observation (max 10 words) that matches the scene. Like 'Every meal starts with curiosity'. Just the text.",
        "position": "center",
        "bg_style": "blur",
    },
    "fact": {
        "prompt": "Look at this image. Write ONE interesting fact or milestone (max 10 words) shown in the photo. Like '15 students, 1 big pot, endless learning'. Just the text.",
        "position": "bottom",
        "bg_style": "solid",
    },
    "minimal": {
        "prompt": "Look at this image. Write ONE minimal, elegant label (max 5 words). Like 'Learning in action'. Just the text.",
        "position": "top",
        "bg_style": "transparent",
    },
}

def get_font(size):
    """Get best available font."""
    font_paths = [
        "/System/Library/Fonts/Helvetica.ttc",
        "/System/Library/Fonts/Arial.ttf",
        "/Library/Fonts/Arial.ttf",
        "/System/Library/Fonts/Supplemental/Arial.ttf",
    ]
    for path in font_paths:
        if os.path.exists(path):
            try:
                return ImageFont.truetype(path, size)
            except:
                pass
    return ImageFont.load_default()

def clean_gemma_output(text):
    """Strip thinking tags and cleanup from Gemma 4 output."""
    if not text:
        return ""
    
    # Remove everything before "done thinking" if present
    if "done thinking" in text.lower():
        text = text.lower().split("done thinking.")[-1]
        # Restore case by finding in original
        if "done thinking" in text:
            text = text[text.find("done thinking") + len("done thinking"):]
    
    # Remove everything before last "Caption:" or "Text:" or similar
    for marker in ["Caption:", "Text:", "Output:", "Final caption:", "Final output:", "Final answer:", "Answer:"]:
        if marker in text:
            text = text.split(marker)[-1]
    
    # Remove thinking blocks
    if "<thinking>" in text and "</thinking>" in text:
        text = text.split("</thinking>")[-1]
    elif "<thinking>" in text:
        text = text.split("<thinking>")[0]
    
    # Remove markdown and process text
    text = text.replace("**", "").replace("*", "")
    
    # Split lines and filter
    lines = []
    skip_patterns = [
        "Analyze", "Determine", "Drafting", "Final Polish", "Selecting",
        "Final Output", "done thinking", "Option 1:", "Option 2:", "Option 3:",
        "Pro-Tip", "Hashtags:", "Keywords:", "Brainstorming", "Thinking...",
        "Here's a thinking", "Core Message", "Requirements:", "Constraints:",
        "Step ", "1. ", "2. ", "3. ", "4. ", "5. ", "6. ", "7. ", "8. ", "9. ",
        "- ", "* ", "> ", "Client:", "Event:", "Tone:", "Goal:", "Output",
        "Idea:", "Refining", "Warm Tone", "Focus on", "Aim for",
        "(A bit", "(Too", "(Good", "(Better", "(Strong", "(Very", "(Similar",
        "This leads", "Ensure", "Need", "Must", "Should", "Could", "Would",
    ]
    
    for line in text.split("\n"):
        line = line.strip()
        # Skip control chars
        if "[K" in line or "[D" in line or "[A" in line:
            continue
        # Skip lines starting with skip patterns
        if any(line.startswith(p) for p in skip_patterns):
            continue
        # Skip lines containing skip patterns at start
        if any(line.lower().startswith(p.lower()) for p in skip_patterns):
            continue
        # Skip lines that are just numbers or bullets
        if line and not line[0].isdigit() and line[0] not in '-*>':
            if line:
                lines.append(line)
    
    # Join and clean
    result = " ".join(lines)
    
    # Remove extra whitespace
    result = " ".join(result.split())
    
    return result.strip()

def analyze_image_with_vision(image_path):
    """Use Gemma 4 vision to analyze image."""
    try:
        import urllib.request
        import json
        import base64
        
        with open(image_path, "rb") as f:
            image_data = base64.b64encode(f.read()).decode('utf-8')
        
        data = json.dumps({
            "model": "gemma4:e4b-q4",
            "prompt": "Describe what's happening in this image in 2 sentences. Be specific.",
            "images": [image_data],
            "stream": False
        }).encode('utf-8')
        
        req = urllib.request.Request(
            "http://localhost:11434/api/generate",
            data=data,
            headers={"Content-Type": "application/json"}
        )
        
        with urllib.request.urlopen(req, timeout=60) as resp:
            result = json.loads(resp.read().decode())
            description = result.get("response", "").strip()
            description = clean_gemma_output(description)
        
        return description if description else "A moment at our school"
    except Exception as e:
        print(f"  ⚠️ Vision not available ({str(e)[:30]}), using text-only generation")
        return "A moment at our school"

def generate_creative_text(image_path, style="storytelling", event_name=""):
    """Generate creative text overlay based on image content."""
    
    style_config = TEXT_STYLES.get(style, TEXT_STYLES["storytelling"])
    
    # Try vision first, fallback to text-only
    description = analyze_image_with_vision(image_path)
    
    # Generate creative text
    prompt = f"""Write ONE short, creative Instagram text overlay (max 8 words) for this school photo.

Scene: {description}
Event: {event_name}
Style: {style}

Examples of good text:
- "From 200 gm to 3 kg"
- "Little hands, big dreams"  
- "Every meal starts with curiosity"
- "Learning happens in every moment"

Write ONLY the text, nothing else:
"""
    
    try:
        result = subprocess.run(
            ["ollama", "run", VISION_MODEL, prompt],
            capture_output=True,
            text=True,
            timeout=60
        )
        
        text = clean_gemma_output(result.stdout)
        
        # Limit length
        words = text.split()
        if len(words) > 10:
            text = " ".join(words[:10])
        
        return text if text else f"{event_name} at {SCHOOL_NAME}"
    except Exception as e:
        print(f"  ⚠️ Creative text failed: {e}")
        return f"{event_name} at {SCHOOL_NAME}"

def generate_storytelling_caption(event_name, image_descriptions):
    """Generate storytelling captions from image analysis."""
    
    combined_desc = " | ".join(image_descriptions[:3])
    
    prompt = f"""Write a SHORT Instagram caption (max 3 sentences) for a school called "{SCHOOL_NAME}".

Event: {event_name}
What happened: {combined_desc}

Requirements:
- Warm, personal, storytelling tone
- Max 3 sentences
- 3-5 relevant hashtags at the end
- No emojis in the main text

Write ONLY the caption and hashtags, nothing else:
"""
    
    try:
        result = subprocess.run(
            ["ollama", "run", VISION_MODEL, prompt],
            capture_output=True,
            text=True,
            timeout=60
        )
        
        caption = clean_gemma_output(result.stdout)
        
        return caption if len(caption) > 20 else f"{event_name} at {SCHOOL_NAME}! Learning happens in every moment. #SchoolLife #Education"
    except:
        return f"{event_name} at {SCHOOL_NAME}! Learning happens in every moment. #SchoolLife #Education"

def apply_text_overlay(img, text, position="center", bg_style="gradient", font_size=70):
    """Apply creative text overlay with various styles."""
    
    draw = ImageDraw.Draw(img)
    width, height = img.size
    font = get_font(font_size)
    
    # Wrap text
    words = text.split()
    lines = []
    current_line = []
    max_width = width - 100
    
    for word in words:
        test = ' '.join(current_line + [word])
        bbox = draw.textbbox((0, 0), test, font=font)
        if bbox[2] <= max_width:
            current_line.append(word)
        else:
            if current_line:
                lines.append(' '.join(current_line))
            current_line = [word]
    if current_line:
        lines.append(' '.join(current_line))
    
    if not lines:
        lines = [text]
    
    # Calculate text block
    line_height = font_size + 15
    total_height = len(lines) * line_height + 40
    max_line_width = max(draw.textbbox((0, 0), line, font=font)[2] for line in lines)
    
    # Position
    if position == "center":
        y_start = (height - total_height) // 2
        x_base = (width - max_line_width) // 2
    elif position == "top":
        y_start = 60
        x_base = (width - max_line_width) // 2
    elif position == "bottom":
        y_start = height - total_height - 60
        x_base = (width - max_line_width) // 2
    else:  # corner
        y_start = height - total_height - 40
        x_base = 40
    
    # Background style
    overlay = Image.new('RGBA', img.size, (0, 0, 0, 0))
    overlay_draw = ImageDraw.Draw(overlay)
    
    if bg_style == "gradient":
        # Gradient from center
        for i in range(total_height + 40):
            alpha = int(180 * (1 - abs(i - (total_height + 40) / 2) / ((total_height + 40) / 2)))
            overlay_draw.line(
                [(0, y_start - 20 + i), (width, y_start - 20 + i)],
                fill=(0, 0, 0, max(alpha, 80))
            )
    elif bg_style == "blur":
        # Solid dark with blur effect (simulated with transparency)
        overlay_draw.rectangle(
            [(x_base - 30, y_start - 20), (x_base + max_line_width + 30, y_start + total_height + 20)],
            fill=(0, 0, 0, 160)
        )
    elif bg_style == "solid":
        overlay_draw.rectangle(
            [(0, y_start - 20), (width, y_start + total_height + 20)],
            fill=(0, 0, 0, 180)
        )
    else:  # transparent
        pass
    
    # Draw text with shadow
    y = y_start
    for line in lines:
        bbox = draw.textbbox((0, 0), line, font=font)
        line_w = bbox[2] - bbox[0]
        x = x_base if position != "corner" else 40
        
        # Shadow
        overlay_draw.text((x + 2, y + 2), line, font=font, fill=(0, 0, 0, 180))
        # Main text
        overlay_draw.text((x, y), line, font=font, fill=(255, 255, 255, 255))
        y += line_height
    
    return Image.alpha_composite(img.convert('RGBA'), overlay).convert('RGB')

def create_video_slideshow(photos, output_path, event_name, duration=3):
    """Create video reel from photos with transitions."""
    
    if not photos:
        return False
    
    try:
        # Use ffmpeg if available
        result = subprocess.run(["which", "ffmpeg"], capture_output=True, text=True)
        if result.returncode != 0:
            print("  ⚠️ ffmpeg not installed. Install with: brew install ffmpeg")
            return False
        
        # Create temp directory for frames
        temp_dir = os.path.join(os.path.dirname(output_path), ".temp_video")
        os.makedirs(temp_dir, exist_ok=True)
        
        frame_count = 0
        fps = 30
        frames_per_photo = duration * fps
        
        for photo_path in photos[:10]:  # Max 10 photos
            img = Image.open(photo_path)
            # Resize to reel size
            img = img.resize((1080, 1920), Image.LANCZOS)
            
            # Add text
            text = generate_creative_text(photo_path, "storytelling", event_name)
            img = apply_text_overlay(img, text, "center", "gradient", 60)
            
            # Save frames
            for i in range(frames_per_photo):
                frame_path = os.path.join(temp_dir, f"frame_{frame_count:05d}.jpg")
                img.save(frame_path, quality=95)
                frame_count += 1
        
        # Compile with ffmpeg
        cmd = [
            "ffmpeg", "-y",
            "-framerate", str(fps),
            "-i", os.path.join(temp_dir, "frame_%05d.jpg"),
            "-c:v", "libx264",
            "-pix_fmt", "yuv420p",
            "-vf", "fade=t=out:st=0:d=0.5",
            output_path
        ]
        
        subprocess.run(cmd, capture_output=True, timeout=120)
        
        # Cleanup
        shutil.rmtree(temp_dir)
        
        return os.path.exists(output_path)
    except Exception as e:
        print(f"  ⚠️ Video creation failed: {e}")
        return False

def process_image_v2(input_path, output_dir, event_name, style="storytelling"):
    """Process single image with creative text."""
    
    filename = Path(input_path).stem
    results = {}
    
    try:
        img = Image.open(input_path)
    except Exception as e:
        print(f"  ❌ Cannot open {input_path}: {e}")
        return results
    
    # Generate creative text based on image content
    print(f"  🔍 Analyzing image...")
    creative_text = generate_creative_text(input_path, style, event_name)
    print(f"  ✍️  Text: '{creative_text}'")
    
    style_config = TEXT_STYLES.get(style, TEXT_STYLES["storytelling"])
    
    # Process each size
    for size_name, (target_w, target_h) in SIZES.items():
        size_dir = os.path.join(output_dir, size_name)
        os.makedirs(size_dir, exist_ok=True)
        
        img_copy = img.copy()
        img_w, img_h = img_copy.size
        
        # Smart crop (center, but prefer top for portraits)
        target_ratio = target_w / target_h
        img_ratio = img_w / img_h
        
        if img_ratio > target_ratio:
            new_w = int(img_h * target_ratio)
            left = (img_w - new_w) // 2
            img_copy = img_copy.crop((left, 0, left + new_w, img_h))
        else:
            new_h = int(img_w / target_ratio)
            # For reels/stories, prefer top (faces usually upper half)
            if size_name in ["reel", "story"]:
                top = 0
            else:
                top = (img_h - new_h) // 2
            img_copy = img_copy.crop((0, top, img_w, top + new_h))
        
        img_copy = img_copy.resize((target_w, target_h), Image.LANCZOS)
        
        # Apply creative text overlay
        if size_name == "post":
            # School name small at bottom
            img_copy = apply_text_overlay(img_copy, SCHOOL_NAME, "bottom", "solid", 40)
        elif size_name == "reel":
            # Creative text centered
            img_copy = apply_text_overlay(img_copy, creative_text, style_config["position"], style_config["bg_style"], 65)
        elif size_name == "story":
            # Creative text + swipe indicator
            img_copy = apply_text_overlay(img_copy, creative_text, "center", "gradient", 55)
            img_copy = apply_text_overlay(img_copy, "Swipe up →", "bottom", "transparent", 35)
        else:  # portrait
            img_copy = apply_text_overlay(img_copy, creative_text, "bottom", "solid", 55)
        
        output_path = os.path.join(size_dir, f"{filename}_{size_name}.jpg")
        img_copy.save(output_path, "JPEG", quality=95)
        
        results[size_name] = {
            "path": output_path,
            "text": creative_text,
        }
    
    return results, creative_text

def main():
    parser = argparse.ArgumentParser(description="InstaGen v2 - Advanced School Instagram Content Generator")
    parser.add_argument("--input", "-i", required=True, help="Input folder with photos")
    parser.add_argument("--output", "-o", default="~/Desktop/instagen_output", help="Output folder")
    parser.add_argument("--event", "-e", required=True, help="Event name")
    parser.add_argument("--style", "-s", default="storytelling", 
                       choices=["storytelling", "quote", "fact", "minimal"],
                       help="Text overlay style")
    parser.add_argument("--video", "-v", action="store_true", help="Create video reel from photos")
    
    args = parser.parse_args()
    
    input_dir = os.path.expanduser(args.input)
    output_dir = os.path.expanduser(args.output)
    
    # Check deps
    try:
        from PIL import Image
    except ImportError:
        print("❌ Pillow not installed. Run: pip3 install Pillow")
        sys.exit(1)
    
    try:
        subprocess.run(["ollama", "list"], capture_output=True, check=True)
    except:
        print("❌ Ollama not found. Is it installed and running?")
        sys.exit(1)
    
    input_path = Path(input_dir)
    if not input_path.exists():
        print(f"❌ Input directory not found: {input_dir}")
        sys.exit(1)
    
    output_path = Path(output_dir)
    output_path.mkdir(parents=True, exist_ok=True)
    
    # Find images
    extensions = {'.jpg', '.jpeg', '.png', '.heic', '.heif'}
    images = sorted([f for f in input_path.iterdir() if f.suffix.lower() in extensions])
    
    if not images:
        print(f"❌ No images found in {input_dir}")
        sys.exit(1)
    
    print(f"🎓 InstaGen v2 - {args.style.upper()} style")
    print(f"🏫 {SCHOOL_NAME}")
    print(f"📸 Processing {len(images)} photos from: {args.event}")
    print()
    
    all_results = {}
    all_texts = []
    all_descriptions = []
    
    for i, img_path in enumerate(images, 1):
        print(f"  [{i}/{len(images)}] {img_path.name}")
        
        results, text = process_image_v2(str(img_path), str(output_path), args.event, args.style)
        all_results[img_path.stem] = results
        all_texts.append(text)
        
        # Get description for captions
        desc = analyze_image_with_vision(str(img_path))
        all_descriptions.append(desc)
    
    # Generate storytelling captions
    print("\n  ✍️  Generating storytelling captions...")
    main_caption = generate_storytelling_caption(args.event, all_descriptions)
    
    # Individual captions
    individual_captions = []
    for i, (text, desc) in enumerate(zip(all_texts, all_descriptions), 1):
        prompt = f"""Write a short Instagram caption (1-2 sentences) for this school photo.

Overlay text: {text}
Event: {args.event}
School: {SCHOOL_NAME}

Requirements:
- Warm, personal tone
- Reference the overlay text naturally
- 1-2 sentences only
- Include 2-3 hashtags

Write ONLY the caption, nothing else:
"""
        try:
            result = subprocess.run(
                ["ollama", "run", VISION_MODEL, prompt],
                capture_output=True, text=True, timeout=30
            )
            cap = clean_gemma_output(result.stdout)
            if len(cap) < 10:
                cap = f"{text}. {args.event} at {SCHOOL_NAME}!"
        except:
            cap = f"{text}. {args.event} at {SCHOOL_NAME}!"
        
        individual_captions.append(cap)
    
    # Save captions file
    captions_path = output_path / "captions.txt"
    with open(captions_path, "w") as f:
        f.write(f"🎓 {SCHOOL_NAME}\n")
        f.write(f"📅 Event: {args.event}\n")
        f.write(f"📊 Total photos: {len(images)}\n")
        f.write(f"🎨 Style: {args.style}\n")
        f.write("=" * 60 + "\n\n")
        
        f.write("📝 MAIN CAPTION (for carousel/post series):\n")
        f.write(main_caption + "\n\n")
        f.write("=" * 60 + "\n\n")
        
        f.write("📸 INDIVIDUAL CAPTIONS:\n\n")
        for i, (filename, cap) in enumerate(zip(all_results.keys(), individual_captions), 1):
            f.write(f"Photo {i}: {filename}\n")
            f.write(f"Overlay text: {all_texts[i-1]}\n")
            f.write(f"Caption: {cap}\n\n")
    
    # Create video if requested
    if args.video:
        print("\n  🎬 Creating video reel...")
        video_path = output_path / f"{args.event.replace(' ', '_')}_reel.mp4"
        photo_paths = [str(results["reel"]["path"]) for results in all_results.values() if "reel" in results]
        if create_video_slideshow(photo_paths, str(video_path), args.event):
            print(f"  ✅ Video: {video_path}")
    
    # Summary
    summary = {
        "school": SCHOOL_NAME,
        "event": args.event,
        "total_photos": len(images),
        "style": args.style,
        "output_folder": str(output_path),
        "sizes_created": list(SIZES.keys()),
    }
    
    summary_path = output_path / "summary.json"
    with open(summary_path, "w") as f:
        json.dump(summary, f, indent=2)
    
    print()
    print("✅ InstaGen v2 Complete!")
    print(f"📁 Output: {output_path}")
    print(f"📄 Captions: captions.txt")
    print()
    print("Folder structure:")
    for size_name in SIZES.keys():
        size_dir = output_path / size_name
        count = len(list(size_dir.glob("*.jpg"))) if size_dir.exists() else 0
        print(f"  📂 {size_name}/ - {count} files")
    
    if args.video and video_path.exists():
        print(f"  🎬 Video: {video_path.name}")
    
    print()
    print("💡 Key improvements in v2:")
    print("  ✓ Vision analysis - AI sees what's in each photo")
    print("  ✓ Creative text - contextual overlays, not generic")
    print("  ✓ Storytelling captions - warm, personal tone")
    print("  ✓ Multiple styles - storytelling, quote, fact, minimal")
    print("  ✓ Video creation - slideshow reels from photos")
    print()
    print("🎯 For admin: Review photos, pick best captions, post!")

if __name__ == "__main__":
    main()
